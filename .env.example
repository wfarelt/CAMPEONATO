# ─────────────────────────────────────────────
#  Django – Variables de entorno (EJEMPLO)
#  Copiar este archivo a .env y completar los valores
# ─────────────────────────────────────────────

# Seguridad
SECRET_KEY=cambia-esto-por-una-clave-secreta-segura
DEBUG=False

# Hosts permitidos (separados por coma)
ALLOWED_HOSTS=tudominio.com,www.tudominio.com

# Base de datos SQLite3
DATABASE_URL=sqlite:///db.sqlite3

# Archivos estáticos y media
STATIC_URL=/static/
MEDIA_URL=/media/

# CORS
CORS_ALLOW_ALL_ORIGINS=False
CORS_ALLOWED_ORIGINS=https://tudominio.com,https://www.tudominio.com

# Seguridad HTTP (activar cuando haya HTTPS)
SECURE_SSL_REDIRECT=True
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True
SECURE_HSTS_SECONDS=31536000
SECURE_HSTS_INCLUDE_SUBDOMAINS=True
SECURE_HSTS_PRELOAD=True
